# =============================================================================
# SENSITIVE DATA PROTECTION
# =============================================================================
# Environment files with actual secrets
.env
.env.local
.env.production
.env.development
.env.staging
.env.prod
.env.dev
.env.test
**/.env
!**/.env.example
!**/.env.local.example

# Terraform variable files with secrets
*.tfvars
!*.tfvars.example
!terraform.tfvars.example
terraform.tfvars
dev.auto.tfvars
prod.auto.tfvars
staging.auto.tfvars
secrets.tfvars
*.secret.tfvars

# AWS and Cloud credentials
.aws/
aws-credentials.json
credentials.json
secrets.json
config.json
*.pem
*.key
*.crt
*.p12
*.pfx

# API Keys and Tokens
api_keys.json
tokens.json
auth_tokens.json
jwt_secrets.json
oauth_credentials.json

# Database credentials
db_credentials.json
database_config.json
connection_strings.json

# Third-party service credentials
google_credentials.json
slack_credentials.json
pinecone_credentials.json
bedrock_credentials.json

