  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://YOUR_API_ID.execute-api.us-east-1.amazonaws.com/dev",
      "type": "string",
      "description": "HTTP API base URL - replace YOUR_API_ID with actual API Gateway ID"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string",
      "description": "JWT token from authentication"
    },
    {
      "key": "google_id_token",
      "value": "",
      "type": "string",
      "description": "Google OAuth ID token for authentication"
    },
    {
      "key": "conversation_id",
      "value": "",
      "type": "string",
      "description": "Current conversation ID"
    },
    {
      "key": "session_id",
      "value": "",
      "type": "string",
      "description": "Research session ID for follow-up questions"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string",
      "description": "Authenticated user ID"
    },
    {
      "key": "ticker",
      "value": "AAPL",
      "type": "string",
      "description": "Stock ticker symbol for research queries"
    }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "description": "Google OAuth authentication flow",
      "item": [
        {
          "name": "Auth Callback - Get JWT Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Parse response",
                  "var jsonData = pm.response.json();",
                  "",
                  "// Store JWT token",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set('jwt_token', jsonData.token);",
                  "    console.log('JWT token saved successfully');",
                  "}",
                  "",
                  "// Store user ID",
                  "if (jsonData.user && jsonData.user.id) {",
                  "    pm.collectionVariables.set('user_id', jsonData.user.id);",
                  "    console.log('User ID saved:', jsonData.user.id);",
                  "}",
                  "",
                  "// Tests",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains token', function () {",
                  "    pm.expect(jsonData).to.have.property('token');",
                  "});",
                  "",
                  "pm.test('Response contains user object', function () {",
                  "    pm.expect(jsonData).to.have.property('user');",
                  "    pm.expect(jsonData.user).to.have.property('id');",
                  "    pm.expect(jsonData.user).to.have.property('email');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"credential\": \"{{google_id_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/callback",
              "host": ["{{base_url}}"],
              "path": ["auth", "callback"]
            },
            "description": "Exchange Google OAuth ID token for JWT.\n\n**How to get the Google ID token:**\n1. Go to your BuffettGPT frontend app\n2. Sign in with Google\n3. Open browser DevTools > Network tab\n4. Look for the `/auth/callback` request\n5. Copy the `credential` value from the request payload\n6. Set it as the `google_id_token` collection variable"
          },
          "response": []
        },
        {
          "name": "Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "pm.test('Health check returns status', function () {",
                  "    pm.expect(jsonData).to.have.property('status');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Health check endpoint to verify API is running"
          },
          "response": []
        }
      ]
