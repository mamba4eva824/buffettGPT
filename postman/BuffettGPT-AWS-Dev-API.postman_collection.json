{
  "info": {
    "_postman_id": "buffettgpt-aws-dev-api",
    "name": "BuffettGPT AWS Dev API",
    "description": "API collection for testing BuffettGPT AWS dev environment - Authentication, Conversations, Research Follow-up, and Token Tracking.\n\nArchitecture: Tool-based LLM orchestration using Claude Haiku with direct Bedrock model invocation.",
