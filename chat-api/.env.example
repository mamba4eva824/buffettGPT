# Backend Lambda local env example
# Copy to .env and fill with your values or leave defaults for local testing.

# General
ENVIRONMENT=dev
PROJECT_NAME=buffett-chat-api
LOG_LEVEL=INFO
AWS_REGION=us-east-1
# Optional when using local AWS creds
# AWS_PROFILE=default

# DynamoDB (used by handlers)
CHAT_SESSIONS_TABLE=dev-chat-sessions
CHAT_MESSAGES_TABLE=dev-chat-messages

# SQS for async processing
CHAT_PROCESSING_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/dev-chat-processing

# Amazon Bedrock Agent config
BEDROCK_AGENT_ID=your-agent-id
BEDROCK_AGENT_ALIAS=your-agent-alias-id
BEDROCK_REGION=us-east-1

