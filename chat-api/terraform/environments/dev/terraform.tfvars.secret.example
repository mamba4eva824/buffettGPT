# SENSITIVE VALUES - DO NOT COMMIT TO GIT
# Copy this file to terraform.tfvars.secret and add to .gitignore

# Google OAuth Configuration
google_client_secret = "GOCSPX-xxxxxxxxxxxxxxxxxxxxx"  # Get from Google Cloud Console

# JWT Secret for token signing (generate a secure random string)
# You can generate one with: openssl rand -base64 32
jwt_secret = "your-super-secure-jwt-secret-key-here"