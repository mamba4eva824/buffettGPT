# Terraform files
*.tfstate
*.tfstate.*
*.tfplan
.terraform/
.terraform.lock.hcl

# Secret files - NEVER commit these
*.secret
terraform.tfvars.secret
**/terraform.tfvars.secret
secrets.tfvars
.env

