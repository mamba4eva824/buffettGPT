# Example terraform.tfvars file
# Copy this to terraform.tfvars and update with your actual values

# Required: Your Pinecone API key (NEVER commit real keys to version control!)
# Get your API key from: https://app.pinecone.io/organizations/-/projects/-/keys
pinecone_api_key = "YOUR_PINECONE_API_KEY_HERE"

# Optional: Override default configuration
# pinecone_connection_string = "https://your-pinecone-index.svc.region.pinecone.io"
# source_bucket_arn = "arn:aws:s3:::your-source-bucket"
# knowledge_base_name = "your-kb-name"
# agent_name = "your-agent-name"