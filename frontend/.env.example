# Environment Configuration Template
# Copy this file to .env.development or .env.production and update the values

VITE_APP_NAME=Buffett
VITE_ENVIRONMENT=development

# AWS API Gateway URLs
VITE_REST_API_URL=https://your-http-api-id.execute-api.region.amazonaws.com/stage

# Follow-up Agent - Docker Lambda Function URL (SSE streaming via FastAPI + LWA)
VITE_ANALYSIS_FOLLOWUP_URL=https://your-function-id.lambda-url.region.on.aws/followup

# Feature Flags
VITE_ENABLE_DEBUG_LOGS=true
VITE_ENABLE_DEMO_MODE=true

# Default User Settings
VITE_DEFAULT_USER_NAME=guest
