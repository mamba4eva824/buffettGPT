# Production Environment Configuration
VITE_APP_NAME=Warren Buffett Chat AI
VITE_ENVIRONMENT=production

# AWS API Gateway URLs (Production)
# TODO: Update these with production API Gateway URLs when deployed
VITE_WEBSOCKET_URL=wss://your-prod-websocket-id.execute-api.us-east-1.amazonaws.com/prod
VITE_REST_API_URL=https://your-prod-http-api-id.execute-api.us-east-1.amazonaws.com/prod

# Feature Flags
VITE_ENABLE_DEBUG_LOGS=false
VITE_ENABLE_DEMO_MODE=false

# Default User Settings
VITE_DEFAULT_USER_NAME=guest
