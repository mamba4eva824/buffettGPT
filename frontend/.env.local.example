# Local Development Environment Override
# Copy this file to .env.local and update with your actual values
# .env.local will override .env.development values
# Note: .env.local is gitignored and won't be committed

# Your Actual API URLs (from AWS deployment)
VITE_WEBSOCKET_URL=wss://your-websocket-api.execute-api.us-east-1.amazonaws.com/dev
VITE_REST_API_URL=https://your-rest-api.execute-api.us-east-1.amazonaws.com/dev

# Your Google OAuth Client ID
# Get this from Google Cloud Console -> APIs & Services -> Credentials
VITE_GOOGLE_CLIENT_ID=your-actual-google-client-id.apps.googleusercontent.com

# Optional: Override other settings for local testing
# VITE_ENABLE_DEBUG_LOGS=true
# VITE_ENABLE_DEMO_MODE=false